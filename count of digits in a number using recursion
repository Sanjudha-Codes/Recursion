Using recurion:

n=int(input("n="))

def countn(n):
    if n==0:
        return 
    return n%10 + countn(n//10)
        
print (countn(n)) 


Non-recursion:

n=int(input("n="))

def countn(n):
    if n%10==n:
        return 1
    c=0        
    while(n>1):
        c=n%10
        if c!=0:
            return 1+countn(n//10)   
        
print (countn(n))    
